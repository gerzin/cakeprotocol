CompileFlags:
  Add:
    - "-std=c++23"
    - "-xc++"
  Remove:
    - "-fno-canonical-system-headers"
    - "*-canonical-system-headers"
  CompilationDatabase: .

Diagnostics:
  UnusedIncludes: Strict
  ClangTidy:
    Add:
      - modernize-*
      - performance-*
      - readability-*
      - bugprone-*
    Remove:
      - modernize-use-trailing-return-type

InlayHints:
  Enabled: true
  ParameterNames: true
  DeducedTypes: true

---
# Suppress everything under third_party/
If:
  PathMatch: "third_party/.*"
Diagnostics:
  Suppress: "*"
  ClangTidy:
    Remove:
      - "*"
